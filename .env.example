# Kopieer dit bestand naar ".env" en vul je eigen waarden in.

# Te vinden op https://discord.com/developers/applications -> jouw app -> OAuth2
DISCORD_CLIENT_ID=jouw_client_id
DISCORD_CLIENT_SECRET=jouw_client_secret

# Moet EXACT overeenkomen met de "Redirect" die je bij Discord instelt
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Willekeurige lange random string (voor het versleutelen van sessies & tokens)
SESSION_SECRET=verander_dit_in_iets_lang_en_willekeurigs
TOKEN_ENCRYPTION_KEY=verander_dit_ook_32_tekens_lang!!

# Discord ID('s) die op deze installatie ALTIJD overal bij mogen (ook bots van
# anderen) — komma-gescheiden. Leeg/weglaten = alleen het standaard-ID hieronder.
SUPER_ADMIN_IDS=1179804729254105210

PORT=8000
